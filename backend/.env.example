# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# On Render, use the Internal Database URL values from your PostgreSQL service
DB_HOST=your-render-db-host
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_string
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=https://your-frontend.vercel.app

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Example values below are for Gmail; adjust for your provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=PregnancyCare
