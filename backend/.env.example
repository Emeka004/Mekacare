NODE_ENV=production
PORT=5000

DB_HOST=Internal Database Host
DB_PORT=5432
DB_NAME=pregnancy_health_db
DB_USER=postgres
DB_PASSWORD=postgres          # or whatever you set during PostgreSQL install

JWT_SECRET=any_32_plus_character_string_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_32_plus_character_string
JWT_REFRESH_EXPIRES_IN=30d

CLIENT_URL=https://mekacare.vercel.app/

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Example values below are for Gmail; adjust for your provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=PregnancyCare
